---
const title = "Kamininstallation.se — Lanseras 2026";
const description = "Sveriges nya plattform för professionell kamininstallation. Lanseras under 2026.";
---

<html lang="sv">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Inter:wght@300;400;500&display=swap" rel="stylesheet" />
  </head>
  <body>
    <div class="bg-layer"></div>
    <div class="overlay"></div>

    <div class="particles" aria-hidden="true">
      <span class="ember"></span>
      <span class="ember"></span>
      <span class="ember"></span>
      <span class="ember"></span>
      <span class="ember"></span>
      <span class="ember"></span>
      <span class="ember"></span>
      <span class="ember"></span>
    </div>

    <main>
      <div class="content">
        <div class="logo-mark">
          <svg viewBox="0 0 60 60" fill="none" xmlns="http://www.w3.org/2000/svg" class="icon">
            <path d="M30 5 C30 5 15 20 15 35 C15 43.284 21.716 50 30 50 C38.284 50 45 43.284 45 35 C45 20 30 5 30 5Z" fill="url(#flame-grad)" opacity="0.9"/>
            <path d="M30 22 C30 22 22 30 22 37 C22 41.418 25.582 45 30 45 C34.418 45 38 41.418 38 37 C38 30 30 22 30 22Z" fill="url(#flame-inner)" opacity="0.9"/>
            <defs>
              <linearGradient id="flame-grad" x1="30" y1="5" x2="30" y2="50" gradientUnits="userSpaceOnUse">
                <stop offset="0" stop-color="#FF6B35"/>
                <stop offset="1" stop-color="#D4451A"/>
              </linearGradient>
              <linearGradient id="flame-inner" x1="30" y1="22" x2="30" y2="45" gradientUnits="userSpaceOnUse">
                <stop offset="0" stop-color="#FFD93D"/>
                <stop offset="1" stop-color="#FF8C42"/>
              </linearGradient>
            </defs>
          </svg>
        </div>

        <h1 class="site-name">Kamin<span class="accent">installation</span>.se</h1>

        <div class="divider">
          <span class="line"></span>
          <span class="diamond"></span>
          <span class="line"></span>
        </div>

        <p class="tagline">Professionell kamininstallation i hela Sverige</p>

        <div class="launch-badge">
          <span class="badge-text">Lanseras under 2026</span>
        </div>

        <p class="description">
          Vi bygger Sveriges mest pålitliga plattform för att hitta certifierade
          kamininstallatörer nära dig. Snart kan du enkelt jämföra, boka och
          få din drömkamin installerad av proffs.
        </p>

        <div class="cta-section">
          <a href="mailto:info@kamininstallation.se" class="cta-button">
            <span>Kontakta oss</span>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        </div>
      </div>

      <footer>
        <p>&copy; 2026 Kamininstallation.se</p>
      </footer>
    </main>
  </body>
</html>

<style>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html, body {
    height: 100%;
    overflow: hidden;
    background: #0f0a05;
  }

  body {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    color: #fff;
    position: relative;
  }

  .bg-layer {
    position: fixed;
    inset: 0;
    background:
      url('https://images.unsplash.com/photo-1631630259742-c0f0b17c6c10?w=1920&q=85&auto=format')
      center/cover no-repeat;
    z-index: 0;
    animation: slowZoom 30s ease-in-out infinite alternate;
  }

  @keyframes slowZoom {
    from { transform: scale(1); }
    to { transform: scale(1.08); }
  }

  .overlay {
    position: fixed;
    inset: 0;
    background:
      linear-gradient(
        180deg,
        rgba(15, 10, 5, 0.75) 0%,
        rgba(30, 15, 8, 0.65) 40%,
        rgba(20, 10, 5, 0.80) 100%
      );
    z-index: 1;
  }

  .particles {
    position: fixed;
    inset: 0;
    z-index: 2;
    pointer-events: none;
  }

  .ember {
    position: absolute;
    width: 4px;
    height: 4px;
    background: radial-gradient(circle, #ff9a56 0%, transparent 70%);
    border-radius: 50%;
    animation: float-up linear infinite;
    opacity: 0;
  }

  .ember:nth-child(1) { left: 15%; animation-duration: 8s; animation-delay: 0s; }
  .ember:nth-child(2) { left: 30%; animation-duration: 10s; animation-delay: 2s; }
  .ember:nth-child(3) { left: 50%; animation-duration: 7s; animation-delay: 4s; }
  .ember:nth-child(4) { left: 70%; animation-duration: 9s; animation-delay: 1s; }
  .ember:nth-child(5) { left: 85%; animation-duration: 11s; animation-delay: 3s; }
  .ember:nth-child(6) { left: 25%; animation-duration: 8.5s; animation-delay: 5s; }
  .ember:nth-child(7) { left: 60%; animation-duration: 9.5s; animation-delay: 6s; }
  .ember:nth-child(8) { left: 40%; animation-duration: 7.5s; animation-delay: 7s; }

  @keyframes float-up {
    0% {
      bottom: -5%;
      opacity: 0;
      transform: translateX(0) scale(1);
    }
    10% {
      opacity: 0.8;
    }
    90% {
      opacity: 0.2;
    }
    100% {
      bottom: 105%;
      opacity: 0;
      transform: translateX(40px) scale(0.3);
    }
  }

  main {
    position: relative;
    z-index: 3;
    height: 100vh;
    height: 100dvh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
    text-align: center;
    overflow: hidden;
  }

  .content {
    max-width: 650px;
    animation: fadeInUp 1.2s ease-out;
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .logo-mark {
    margin-bottom: 1.5rem;
    display: flex;
    justify-content: center;
  }

  .icon {
    width: 60px;
    height: 60px;
    filter: drop-shadow(0 0 20px rgba(255, 107, 53, 0.5));
    animation: flicker 3s ease-in-out infinite;
  }

  @keyframes flicker {
    0%, 100% { filter: drop-shadow(0 0 20px rgba(255, 107, 53, 0.5)); }
    50% { filter: drop-shadow(0 0 30px rgba(255, 107, 53, 0.8)); }
  }

  .site-name {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2rem, 5vw, 3.2rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.1;
    text-shadow: 0 2px 20px rgba(0, 0, 0, 0.4);
  }

  .accent {
    color: #FF8C42;
  }

  .divider {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    margin: 1.5rem 0;
  }

  .line {
    display: block;
    width: 60px;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(255, 140, 66, 0.6), transparent);
  }

  .diamond {
    width: 8px;
    height: 8px;
    background: #FF8C42;
    transform: rotate(45deg);
    opacity: 0.8;
  }

  .tagline {
    font-size: clamp(1rem, 2.5vw, 1.2rem);
    font-weight: 300;
    color: rgba(255, 255, 255, 0.85);
    letter-spacing: 0.05em;
    margin-bottom: 2rem;
  }

  .launch-badge {
    display: inline-flex;
    margin-bottom: 2rem;
    padding: 10px 28px;
    border: 1px solid rgba(255, 140, 66, 0.4);
    border-radius: 50px;
    background: rgba(255, 140, 66, 0.08);
    backdrop-filter: blur(10px);
    animation: pulse-border 3s ease-in-out infinite;
  }

  @keyframes pulse-border {
    0%, 100% { border-color: rgba(255, 140, 66, 0.4); box-shadow: 0 0 0 0 rgba(255, 140, 66, 0); }
    50% { border-color: rgba(255, 140, 66, 0.7); box-shadow: 0 0 20px 0 rgba(255, 140, 66, 0.15); }
  }

  .badge-text {
    font-size: 0.9rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #FFB574;
  }

  .description {
    font-size: 1rem;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.7);
    font-weight: 300;
    max-width: 500px;
    margin: 0 auto 2.5rem;
  }

  .cta-button {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 14px 32px;
    background: linear-gradient(135deg, #D4451A 0%, #FF6B35 100%);
    color: #fff;
    text-decoration: none;
    border-radius: 8px;
    font-size: 0.95rem;
    font-weight: 500;
    letter-spacing: 0.03em;
    transition: all 0.3s ease;
    box-shadow: 0 4px 20px rgba(212, 69, 26, 0.3);
  }

  .cta-button:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(212, 69, 26, 0.5);
  }

  .cta-button svg {
    transition: transform 0.3s ease;
  }

  .cta-button:hover svg {
    transform: translateX(4px);
  }

  footer {
    position: absolute;
    bottom: 2rem;
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.35);
    letter-spacing: 0.05em;
  }

  @media (max-width: 640px) {
    main {
      padding: 1.5rem;
    }

    .description {
      font-size: 0.9rem;
    }

    .line {
      width: 40px;
    }
  }
</style>
