---
const title = "BästaKaminen.se — Lanseras 2026";
const description = "Hitta bästa kaminen för ditt hem. Sveriges nya jämförelseportal för kaminer. Lanseras under 2026.";
---

<html lang="sv">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
  </head>
  <body>
    <div class="bg-layer"></div>
    <div class="overlay"></div>

    <div class="glow-orbs" aria-hidden="true">
      <span class="orb orb-1"></span>
      <span class="orb orb-2"></span>
      <span class="orb orb-3"></span>
    </div>

    <main>
      <div class="content">
        <div class="top-label">
          <span class="dot"></span>
          <span>Kommer snart</span>
        </div>

        <h1 class="site-name">
          Bästa<br/>
          <span class="highlight">Kaminen</span>.se
        </h1>

        <p class="tagline">
          Sveriges smartaste sätt att hitta<br class="hide-mobile" />
          rätt kamin för ditt hem
        </p>

        <div class="launch-card">
          <div class="card-glow"></div>
          <div class="card-content">
            <div class="card-icon">
              <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect x="8" y="14" width="32" height="28" rx="3" stroke="currentColor" stroke-width="1.5" fill="none" opacity="0.7"/>
                <path d="M14 14V10C14 7.79 15.79 6 18 6H30C32.21 6 34 7.79 34 10V14" stroke="currentColor" stroke-width="1.5" opacity="0.5"/>
                <path d="M24 22 C24 22 18 27 18 31 C18 34.314 20.686 37 24 37 C27.314 37 30 34.314 30 31 C30 27 24 22 24 22Z" fill="url(#card-flame)" opacity="0.85"/>
                <defs>
                  <linearGradient id="card-flame" x1="24" y1="22" x2="24" y2="37" gradientUnits="userSpaceOnUse">
                    <stop offset="0" stop-color="#E8956A"/>
                    <stop offset="1" stop-color="#C47A5A"/>
                  </linearGradient>
                </defs>
              </svg>
            </div>
            <div class="card-text">
              <span class="card-label">Lanseras under</span>
              <span class="card-year">2026</span>
            </div>
            <div class="card-description">
              Vi jämför kaminer, braskaminer och kamininsatser
              från marknadens ledande tillverkare.
              Opartiska recensioner. Riktiga tester. Bästa priserna.
            </div>
          </div>
        </div>

        <div class="features">
          <div class="feature">
            <div class="feature-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
                <path d="M9 12l2 2 4-4"/>
                <circle cx="12" cy="12" r="10"/>
              </svg>
            </div>
            <span>Oberoende jämförelser</span>
          </div>
          <div class="feature">
            <div class="feature-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
              </svg>
            </div>
            <span>Expertrecensioner</span>
          </div>
          <div class="feature">
            <div class="feature-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
                <path d="M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M1 12h4M19 12h4M4.22 19.78l2.83-2.83M16.95 7.05l2.83-2.83"/>
              </svg>
            </div>
            <span>Bästa priserna</span>
          </div>
        </div>

        <div class="cta-section">
          <a href="mailto:info@bastakaminen.se" class="cta-button">
            Bli notifierad vid lansering
          </a>
        </div>
      </div>

      <footer>
        <p>&copy; 2026 BästaKaminen.se</p>
      </footer>
    </main>
  </body>
</html>

<style>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html, body {
    height: 100%;
    overflow: hidden;
    background: #0a0a0f;
  }

  body {
    font-family: 'DM Sans', -apple-system, BlinkMacSystemFont, sans-serif;
    color: #fff;
    position: relative;
  }

  .bg-layer {
    position: fixed;
    inset: 0;
    background:
      url('https://images.unsplash.com/photo-1613545325278-f24b0cae1224?w=1920&q=85&auto=format')
      center/cover no-repeat;
    z-index: 0;
    animation: drift 25s ease-in-out infinite alternate;
  }

  @keyframes drift {
    from { transform: scale(1.02) translateX(0); }
    to { transform: scale(1.08) translateX(-1%); }
  }

  .overlay {
    position: fixed;
    inset: 0;
    background:
      radial-gradient(
        ellipse at 30% 50%,
        rgba(10, 10, 15, 0.6) 0%,
        rgba(10, 10, 15, 0.85) 100%
      ),
      linear-gradient(
        180deg,
        rgba(5, 5, 10, 0.7) 0%,
        rgba(15, 12, 10, 0.75) 50%,
        rgba(5, 5, 10, 0.85) 100%
      );
    z-index: 1;
  }

  .glow-orbs {
    position: fixed;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    overflow: hidden;
  }

  .orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.12;
  }

  .orb-1 {
    width: 500px;
    height: 500px;
    background: #D4793A;
    top: -10%;
    right: -10%;
    animation: orb-float 15s ease-in-out infinite alternate;
  }

  .orb-2 {
    width: 400px;
    height: 400px;
    background: #8B4A2A;
    bottom: -15%;
    left: -5%;
    animation: orb-float 20s ease-in-out infinite alternate-reverse;
  }

  .orb-3 {
    width: 300px;
    height: 300px;
    background: #C9694A;
    top: 40%;
    left: 50%;
    animation: orb-float 18s ease-in-out infinite alternate;
  }

  @keyframes orb-float {
    from { transform: translate(0, 0); }
    to { transform: translate(30px, -40px); }
  }

  main {
    position: relative;
    z-index: 3;
    height: 100vh;
    height: 100dvh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
    text-align: center;
    overflow: hidden;
  }

  .content {
    max-width: 600px;
    animation: fadeIn 1s ease-out;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .top-label {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #E8956A;
    margin-bottom: 1rem;
  }

  .dot {
    width: 8px;
    height: 8px;
    background: #E8956A;
    border-radius: 50%;
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; box-shadow: 0 0 0 0 rgba(232, 149, 106, 0.4); }
    50% { opacity: 0.7; box-shadow: 0 0 0 8px rgba(232, 149, 106, 0); }
  }

  .site-name {
    font-family: 'DM Serif Display', serif;
    font-size: clamp(2.2rem, 6vw, 4rem);
    font-weight: 400;
    line-height: 1.05;
    letter-spacing: -0.02em;
    margin-bottom: 1rem;
    text-shadow: 0 4px 30px rgba(0, 0, 0, 0.3);
  }

  .highlight {
    background: linear-gradient(135deg, #E8956A 0%, #D4793A 50%, #C9694A 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .tagline {
    font-size: clamp(0.95rem, 2vw, 1.15rem);
    font-weight: 300;
    color: rgba(255, 255, 255, 0.65);
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }

  .hide-mobile {
    display: block;
  }

  .launch-card {
    position: relative;
    margin: 0 auto 1.5rem;
    max-width: 420px;
    border-radius: 16px;
    overflow: hidden;
  }

  .card-glow {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(232, 149, 106, 0.1) 0%, rgba(196, 122, 90, 0.05) 100%);
    border: 1px solid rgba(232, 149, 106, 0.15);
    border-radius: 16px;
    backdrop-filter: blur(20px);
  }

  .card-content {
    position: relative;
    padding: 1.5rem;
  }

  .card-icon svg {
    width: 48px;
    height: 48px;
    color: #E8956A;
    margin-bottom: 1rem;
  }

  .card-text {
    display: flex;
    align-items: baseline;
    justify-content: center;
    gap: 10px;
    margin-bottom: 1rem;
  }

  .card-label {
    font-size: 0.85rem;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.6);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .card-year {
    font-family: 'DM Serif Display', serif;
    font-size: 2rem;
    color: #E8956A;
    letter-spacing: 0.05em;
  }

  .card-description {
    font-size: 0.9rem;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.55);
    font-weight: 300;
  }

  .features {
    display: flex;
    justify-content: center;
    gap: 2rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }

  .feature {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.6);
    font-weight: 400;
  }

  .feature-icon {
    color: rgba(232, 149, 106, 0.7);
    display: flex;
    align-items: center;
  }

  .cta-button {
    display: inline-block;
    padding: 14px 36px;
    background: transparent;
    color: #E8956A;
    text-decoration: none;
    border: 1px solid rgba(232, 149, 106, 0.4);
    border-radius: 50px;
    font-size: 0.9rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    transition: all 0.3s ease;
  }

  .cta-button:hover {
    background: rgba(232, 149, 106, 0.1);
    border-color: rgba(232, 149, 106, 0.7);
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(232, 149, 106, 0.15);
  }

  footer {
    position: absolute;
    bottom: 2rem;
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.25);
    letter-spacing: 0.05em;
  }

  @media (max-width: 640px) {
    main {
      padding: 1.5rem;
    }

    .features {
      gap: 1rem;
    }

    .feature {
      font-size: 0.78rem;
    }

    .hide-mobile {
      display: inline;
    }

    .card-content {
      padding: 1.5rem;
    }
  }
</style>
